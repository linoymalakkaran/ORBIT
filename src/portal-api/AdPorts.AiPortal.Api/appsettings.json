{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [ "https://portal.ai.adports.ae" ],
  "ConnectionStrings": {
    "Portal": "Host=orbit-postgres-dev-rw.ai-portal-data.svc.cluster.local;Port=5432;Database=ai_portal_core;Username=orbit_app;Password=${DB_PASSWORD}",
    "Redis": "orbit-redis-redis-cluster.ai-portal-data.svc.cluster.local:6379,password=${REDIS_PASSWORD}"
  },
  "Keycloak": {
    "Authority": "https://auth.ai.adports.ae/realms/ai-portal",
    "Audience": "portal-api"
  },
  "OpenTelemetry": {
    "Endpoint": "http://otel-collector.monitoring.svc:4317"
  },
  "OpenFga": {
    "ApiUrl": "http://openfga.ai-portal.svc:8080",
    "StoreId": "${OPENFGA_STORE_ID}",
    "AuthorizationModelId": "${OPENFGA_MODEL_ID}"
  },
  "Vault": {
    "Address": "http://vault.vault.svc:8200",
    "AuthPath": "auth/kubernetes/login",
    "Role": "portal-api"
  },
  "Kafka": {
    "BootstrapServers": "orbit-kafka-kafka-bootstrap.kafka.svc:9092",
    "ProducerGroupId": "portal-api-producer"
  },
  "MinIO": {
    "Endpoint": "minio.ai-portal-data.svc.cluster.local:9000",
    "BucketArtifacts": "ai-portal-artifacts",
    "BucketContext": "ai-portal-context-archive"
  }
}
