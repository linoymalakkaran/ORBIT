        <mxCell id="m4-title" value="🚢  FLEET UPGRADE AGENT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#92400E;" vertex="1" parent="1">
          <mxGeometry x="1015" y="660" width="270" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m4-body" value="One decision = campaign across whole portfolio.&#xa;&#xa;Example: .NET 6 → .NET 10 across 40 projects, wave-based, auto-verified by each project's test suite, one-click rollback.&#xa;&#xa;Per-team agent answers prompts from any IDE." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#78350F;" vertex="1" parent="1">
