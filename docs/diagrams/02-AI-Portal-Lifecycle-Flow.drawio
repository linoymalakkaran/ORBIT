        <mxCell id="m3-title" value="🛡  VULNERABILITY RADAR" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#991B1B;" vertex="1" parent="1">
          <mxGeometry x="695" y="660" width="270" height="25" as="geometry" />
