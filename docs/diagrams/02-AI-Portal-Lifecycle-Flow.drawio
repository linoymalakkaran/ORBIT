        <mxCell id="m3-body" value="Continuous scan of every dependency &amp; image across the portfolio.&#xa;&#xa;Critical CVEs → auto-PR with patch + notification.&#xa;&#xa;Zero-day response compressed from weeks to hours." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="695" y="690" width="270" height="115" as="geometry" />
