          <mxGeometry x="375" y="660" width="270" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m2-body" value="Opt-in per project for eligible tickets.&#xa;&#xa;Agent reads Jira ticket → implements → tests → commits → opens PR → transitions to Done with commit SHA.&#xa;&#xa;Humans always merge." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
