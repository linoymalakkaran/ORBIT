{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://portal.adports.ae/schemas/adports-openapi-service.schema.json",
  "title": "AD Ports OpenAPI Service Stub Schema",
  "description": "Validates OpenAPI 3.1 service stubs generated by the Architecture Agent. Enforces AD Ports-specific conventions for paths, security, error responses, and naming.",
  "type": "object",
  "required": ["openapi", "info", "servers", "paths", "components"],
  "properties": {
    "openapi": {
      "type": "string",
      "pattern": "^3\\.(0|1)\\.",
      "description": "Must be OpenAPI 3.0.x or 3.1.x"
    },
    "info": {
      "type": "object",
      "required": ["title", "version", "contact"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Service display name. Pattern: '{ServiceName} API'",
          "pattern": ".+ API$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version"
        },
        "description": { "type": "string" },
        "contact": {
          "type": "object",
          "required": ["name", "email"],
          "properties": {
            "name": { "type": "string" },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "@adports\\.ae$",
              "description": "Must be an AD Ports email"
            }
          }
        },
        "x-domain": {
          "type": "string",
          "enum": ["DGD", "JUL", "PCS", "MPay", "CRM", "ERP", "PORTAL", "NEW"],
          "description": "AD Ports business domain"
        },
        "x-bounded-context": {
          "type": "string",
          "description": "Bounded context within the domain (PascalCase)"
        }
      }
    },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "description"],
        "properties": {
          "url": {
            "type": "string",
            "description": "Must use HTTPS. Pattern: https://{service}.adports.ae/api/v{N}",
            "pattern": "^https://"
          },
          "description": { "type": "string" }
        }
      },
      "description": "Must include at minimum: dev, staging, production servers"
    },
    "paths": {
      "type": "object",
      "description": "API paths. Must follow AD Ports REST conventions.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "get":    { "$ref": "#/definitions/operation" },
          "post":   { "$ref": "#/definitions/operation" },
          "put":    { "$ref": "#/definitions/operation" },
          "patch":  { "$ref": "#/definitions/operation" },
          "delete": { "$ref": "#/definitions/operation" }
        }
      }
    },
    "components": {
      "type": "object",
      "required": ["securitySchemes", "schemas", "responses"],
      "properties": {
        "securitySchemes": {
          "type": "object",
          "required": ["bearerAuth"],
          "properties": {
            "bearerAuth": {
              "type": "object",
              "required": ["type", "scheme", "bearerFormat"],
              "properties": {
                "type":         { "type": "string", "const": "http" },
                "scheme":       { "type": "string", "const": "bearer" },
                "bearerFormat": { "type": "string", "const": "JWT" }
              }
            }
          }
        },
        "schemas": {
          "type": "object",
          "description": "Shared schemas. Must include standard error schemas.",
          "properties": {
            "ProblemDetails": {
              "type": "object",
              "description": "RFC 7807 Problem Details — required for all 4xx/5xx responses",
              "required": ["type", "title", "status", "detail"],
              "properties": {
                "type":     { "type": "object", "properties": { "type": { "const": "string" } } },
                "title":    { "type": "object" },
                "status":   { "type": "object" },
                "detail":   { "type": "object" },
                "instance": { "type": "object" },
                "traceId":  { "type": "object", "description": "OpenTelemetry trace ID for support" }
              }
            },
            "PagedResponse": {
              "type": "object",
              "description": "Standard paginated list response wrapper",
              "required": ["items", "totalCount", "page", "pageSize"],
              "properties": {
                "items":      { "type": "object" },
                "totalCount": { "type": "object" },
                "page":       { "type": "object" },
                "pageSize":   { "type": "object" },
                "hasNext":    { "type": "object" }
              }
            }
          }
        },
        "responses": {
          "type": "object",
          "description": "Standard reusable responses. Must define at minimum: 400, 401, 403, 404, 500.",
          "required": ["BadRequest", "Unauthorized", "Forbidden", "NotFound", "InternalServerError"],
          "properties": {
            "BadRequest":           { "$ref": "#/definitions/error_response" },
            "Unauthorized":         { "$ref": "#/definitions/error_response" },
            "Forbidden":            { "$ref": "#/definitions/error_response" },
            "NotFound":             { "$ref": "#/definitions/error_response" },
            "InternalServerError":  { "$ref": "#/definitions/error_response" }
          }
        }
      }
    },
    "security": {
      "type": "array",
      "description": "Global security must require bearerAuth",
      "contains": {
        "type": "object",
        "required": ["bearerAuth"]
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "operation": {
      "type": "object",
      "required": ["summary", "operationId", "tags", "responses"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Short action description"
        },
        "operationId": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]+$",
          "description": "camelCase operation ID. Must be unique across the spec."
        },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "security": {
          "type": "array",
          "description": "Override if endpoint is public (health checks only)"
        },
        "requestBody": {
          "type": "object",
          "required": ["content"],
          "properties": {
            "required": { "type": "boolean" },
            "content": {
              "type": "object",
              "required": ["application/json"],
              "description": "Must accept application/json"
            }
          }
        },
        "responses": {
          "type": "object",
          "minProperties": 1,
          "description": "Must include at least one 2xx and one error response. 401 and 403 mandatory for authenticated endpoints.",
          "additionalProperties": {
            "type": "object",
            "required": ["description"],
            "properties": {
              "description": { "type": "string" },
              "content": { "type": "object" },
              "$ref": { "type": "string" }
            }
          }
        },
        "x-adports-ledger": {
          "type": "boolean",
          "description": "Set to true for state-changing operations that must record a Pipeline Ledger event"
        },
        "x-adports-openFGA-check": {
          "type": "string",
          "description": "OpenFGA permission check to perform. E.g. 'project:read' or 'project:approve'"
        }
      }
    },
    "error_response": {
      "type": "object",
      "required": ["description", "content"],
      "properties": {
        "description": { "type": "string" },
        "content": {
          "type": "object",
          "required": ["application/problem+json"],
          "properties": {
            "application/problem+json": {
              "type": "object",
              "required": ["schema"],
              "properties": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
